# ============================================================
# Ascension Via Christi RAG System — Environment Configuration
# ============================================================

# REQUIRED: Your OpenAI API Key
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# LLM Model (gpt-4o for best quality, gpt-3.5-turbo for lower cost)
OPENAI_MODEL=gpt-3.5-turbo

# Embedding model (do not change unless you rebuild the index)
EMBEDDING_MODEL=text-embedding-3-small

# RAG Chunking settings
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# Retrieval: how many chunks to pull for each query
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.3

# Paths (relative to backend/)
DOCS_PATH=data/documents
FAISS_INDEX_PATH=data/faiss_index

# Optional Redis caching (leave blank to disable)
REDIS_URL=

# Debug mode
DEBUG=false
